# CerberusAgent — Environment Variables
# Copy to .env and fill in values

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Models — Fallback chain: OPUS > SONNET > HAIKU
MODEL_BODY=claude-sonnet-4-20250514
MODEL_HEADS=claude-sonnet-4-20250514
MODEL_ARBITRE=claude-opus-4-20250514
MODEL_GREFFIER=claude-haiku-4-20250414

# Server
GATEWAY_PORT=3000
COCKPIT_PORT=5173

# Session storage
SESSION_DATA_DIR=./data/sessions
